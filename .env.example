# PingPath - Environment Variables
# Copy this file to .env and fill in the values

# API Server
PORT=3001
HOST=0.0.0.0

# Database path (default: apps/api/data/pingpath.db)
# DB_PATH=/path/to/pingpath.db

# Frontend (set these in apps/web/.env)
# PUBLIC_API_URL=https://your-domain.com/api
# PUBLIC_WS_URL=wss://your-domain.com/ws
